  "backupsSection": {
    "title": "Backups & Data Lifecycle Management",
    "subtitle": "Automated strategies for moving aging files to cold storage and ensuring data redundancy.",
    "industryStandard": {
      "title": "Industry Standard Software",
      "description": "For enterprise video teams, dedicated archiving software is the most reliable way to automate data lifecycle management. These tools integrate directly with high-end NAS systems like the OWC Jellyfish.",
      "items": [
        "<strong>Archiware P5 (Archive):</strong> The industry gold standard. Automatically moves files older than a set threshold (e.g., 5 years) to a cheaper NAS or LTO tape, leaving a tiny stub/proxy file in its place.",
        "<strong>StorageDNA:</strong> A heavy hitter in media archiving that automates the movement of old media to LTO tape or cloud storage based on age.",
        "<strong>Hedge Canister / ChronoSync:</strong> Excellent for Mac-based environments to sync and offload older data safely with checksum verification."
      ]
    },
    "customCoded": {
      "title": "Custom Coded Software",
      "description": "If you prefer a custom, subscription-free approach, we will program a Python app that will run system-specific functions for us to sort and back up files automatically every week.",
      "workflowTitle": "The Workflow:",
      "workflowSteps": [
        "<strong>Trigger:</strong> A cron job (Linux/Mac) or Task Scheduler (Windows) runs the script every Sunday at 2:00 AM.",
        "<strong>Scan:</strong> The script scans the primary "Hot" storage (e.g., Jellyfish) for project folders or files where the "Date Modified" is older than 5 years.",
        "<strong>Transfer:</strong> It uses <code>rsync</code> or a Python equivalent to securely copy the files to the "Cold" Archive NAS (e.g., 45 Drives XL60).",
        "<strong>Verify & Delete:</strong> It verifies the checksums of the copied files to ensure data integrity, then deletes the original high-res files from the Hot storage to free up space.",
        "<strong>Log:</strong> An automated email or Slack/Discord message is sent to the IT/Media Manager with a log of what was moved."
      ]
    }
  }
